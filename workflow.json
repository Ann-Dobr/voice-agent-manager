    {
      "parameters": {
        "jsCode": "// 1. Забираем данные из входящего элемента\nconst item = $input.item;\nconst rawOutput = item.json.output;\n\n// 2. Вытаскиваем Telegram ID пользователя из триггера\nlet tgUserId = null;\ntry {\n    // Дотягиваемся до самого первого узла Telegram Trigger\n    const tgTrigger = $('Telegram Trigger').item.json;\n    tgUserId = tgTrigger.message?.from?.id || tgTrigger.callback_query?.from?.id || null;\n} catch (e) {\n    tgUserId = null;\n}\n\n// 3. Чистим строку от маркдауна и парсим JSON\nlet cleanString = typeof rawOutput === 'string' ? rawOutput : '';\ncleanString = cleanString.replace(/```json/g, '').replace(/```/g, '').trim();\n\nlet parsedData;\ntry {\n    parsedData = JSON.parse(cleanString);\n} catch (e) {\n    parsedData = { intent: 'unknown', agent_name: 'error' };\n}\n\nlet resultQuery = '';\nlet resultParams = [];\n\n// --- СЦЕНАРИЙ 1: СОЗДАНИЕ ---\n// Добавляем tg_user_id в INSERT, чтобы узел \"Мои агенты\" его видел\nif (parsedData.intent === 'create') {\n    resultQuery = `INSERT INTO voice_agents (agent_name, prompt, greeting, kb_content, tg_user_id) VALUES ($1, $2, $3, $4, $5)`;\n    resultParams = [\n        (parsedData.agent_name || \"Без имени\").trim(),\n        \"Ты — полезный ИИ-ассистент.\",\n        \"Привет! Я твой новый агент.\",\n        \"Пустая база знаний\",\n        tgUserId\n    ];\n}\n\n// --- СЦЕНАРИЙ 2: ОБНОВЛЕНИЕ ---\nelse if (parsedData.intent === 'update') {\n    let column = 'prompt';\n    switch (parsedData.type) {\n        case 'prompt': column = 'prompt'; break;\n        case 'greeting': column = 'greeting'; break;\n        case 'kb': column = 'kb_content'; break;\n    }\n    \n    let rawName = parsedData.agent_name || \"\";\n    let finalAgentName = rawName.includes(':') ? rawName.split(':')[1].trim() : rawName.trim();\n    \n    resultQuery = `UPDATE voice_agents SET ${column} = $1 WHERE agent_name = $2`;\n    resultParams = [(parsedData.content || \"\").trim(), finalAgentName];\n}\n\nif (resultQuery !== '') {\n    return [{\n        json: {\n            query: resultQuery,\n            params: resultParams,\n            agentName: parsedData.intent === 'create' \n                ? resultParams[0] \n                : resultParams[1],\n          intent: parsedData.intent\n        }\n    }];\n}\n\nreturn [];"
      },
